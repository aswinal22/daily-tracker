# ─── Supabase ───────────────────────────────────────────────
# For local dev: run `supabase start` and copy the values it prints.
# For prod: use your cloud project's Project URL + anon key + service role key.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Encryption ─────────────────────────────────────────────
# 32-byte base64 key used to encrypt users' AI API keys at rest (AES-256-GCM).
# Generate one locally with:  openssl rand -base64 32
ENCRYPTION_KEY=

# ─── AI default provider (optional) ─────────────────────────
# Users can override these per-account in Settings. Used as the fallback
# when a user has not configured their own provider. Any OpenAI-compatible
# endpoint works (OpenAI, Gemini, Claude, Groq, Ollama, OpenRouter, ...).
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=

# ─── Cron protection ────────────────────────────────────────
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`.
# Protects /api/cron/* endpoints from public access.
CRON_SECRET=
